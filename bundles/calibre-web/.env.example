# Calibre-Web connection
# The URL where Calibre-Web is accessible
CALIBRE_WEB_URL=http://localhost:8083

# API key for authentication (generate in Calibre-Web admin settings)
CALIBRE_WEB_API_KEY=

# Host path to the directory containing your Calibre metadata.db (required for Docker mode)
CALIBRE_WEB_DB_PATH=/path/to/calibre/library
