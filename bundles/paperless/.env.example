# Paperless-ngx connection
# Get an API token from Paperless-ngx Settings > API Tokens
PAPERLESS_URL=http://localhost:8000
PAPERLESS_API_TOKEN=

# Docker mode only — host paths for data and media
PAPERLESS_DATA_PATH=
PAPERLESS_MEDIA_PATH=

# Docker mode only — PostgreSQL password (default: paperless)
PAPERLESS_DB_PASSWORD=
