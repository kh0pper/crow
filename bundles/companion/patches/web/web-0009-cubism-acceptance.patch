+// --- BEGIN CROW PATCH: Cubism SDK first-fetch acceptance -------------
+// Pet mode uses the Live2D Cubism SDK, which is proprietary (Live2D
+// Proprietary Software License). We do not bundle or redistribute it.
+// On first pet-mode entry the user accepts the license in a dialog,
+// then we fetch the SDK from Live2D's CDN, verify a pinned SHA-256,
+// and cache it under ~/.crow/cache/cubism/. Subsequent launches reuse
+// the cached file silently. On cancel, pet mode is skipped for this
+// launch (web-tiled window stays usable). On SHA mismatch, an error
+// dialog points the user at the manual-download flow.
+const CUBISM_SDK_URL =
+  "https://cubism.live2d.com/sdk-web/cubismcore/live2dcubismcore.min.js";
+const CUBISM_SDK_SHA256 =
+  "942783587666a3a1bddea93afd349e26f798ed19dcd7a52449d0ae3322fcff7c";
+const CUBISM_CACHE_DIR = join(homedir(), ".crow", "cache", "cubism");
+const CUBISM_CACHE_PATH = join(CUBISM_CACHE_DIR, "live2dcubismcore.min.js");
+
+function sha256Hex(buf: Buffer): string {
+  return createHash("sha256").update(buf).digest("hex");
+}
+
+function fetchCubismSdk(): Promise<Buffer> {
+  return new Promise((resolveP, rejectP) => {
+    const chunks: Buffer[] = [];
+    const req = electronNet.request(CUBISM_SDK_URL);
+    req.on("response", (res) => {
+      if (res.statusCode !== 200) {
+        rejectP(new Error(`HTTP ${res.statusCode}`));
+        return;
+      }
+      res.on("data", (chunk: Buffer) => chunks.push(chunk));
+      res.on("end", () => resolveP(Buffer.concat(chunks)));
+    });
+    req.on("error", rejectP);
+    req.end();
+  });
+}
+
+async function ensureCubismSdk(): Promise<boolean> {
+  if (existsSync(CUBISM_CACHE_PATH)) {
+    try {
+      const cached = readFileSync(CUBISM_CACHE_PATH);
+      if (sha256Hex(cached) === CUBISM_SDK_SHA256) return true;
+    } catch { /* corrupted — re-fetch */ }
+  }
+  const { response } = await dialog.showMessageBox({
+    type: "question",
+    title: "Live2D Cubism SDK",
+    message: "Pet mode needs the Live2D Cubism SDK (~130 KB).",
+    detail:
+      "Live2D Cubism SDK for Web © Live2D Inc. is published under the "
+      + "Live2D Proprietary Software License. Crow does not bundle or "
+      + "redistribute the SDK — if you accept, the file is downloaded "
+      + "from Live2D's CDN directly into ~/.crow/cache/cubism/. "
+      + "If you cancel, pet mode is disabled for this launch and the "
+      + "web-tiled view stays available.",
+    buttons: ["I accept — download the SDK", "Cancel — disable pet mode"],
+    defaultId: 0,
+    cancelId: 1,
+  });
+  if (response !== 0) return false;
+  let bytes: Buffer;
+  try {
+    bytes = await fetchCubismSdk();
+  } catch (e: any) {
+    await dialog.showErrorBox("Cubism SDK download failed", String(e?.message || e));
+    return false;
+  }
+  const gotHash = sha256Hex(bytes);
+  if (gotHash !== CUBISM_SDK_SHA256) {
+    await dialog.showMessageBox({
+      type: "error",
+      title: "Cubism SDK verification failed",
+      message: "The downloaded SDK did not match the expected SHA-256.",
+      detail:
+        `Expected: ${CUBISM_SDK_SHA256}\nGot:      ${gotHash}\n\n`
+        + "The CDN may be serving a different version. Manually download "
+        + "live2dcubismcore.min.js from https://www.live2d.com/en/sdk/download/web/ "
+        + "and copy it into ~/.crow/cache/cubism/.",
+      buttons: ["OK"],
+    });
+    return false;
+  }
+  mkdirSync(CUBISM_CACHE_DIR, { recursive: true });
+  writeFileSync(CUBISM_CACHE_PATH, bytes);
+  return true;
+}
+// --- END CROW PATCH --------------------------------------------------
+
 let windowManager: WindowManager;
 let menuManager: MenuManager;
 let isQuitting = false;
