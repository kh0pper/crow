+  // --- BEGIN CROW PATCH: pet control socket -------------------------
+  // Unix socket the Crow gateway writes to so `open pet <anchor>`
+  // can re-anchor a running pet without respawning it. Newline-
+  // delimited JSON: { op: "anchor", spec: {...} } → { ok, bounds }.
+  // Socket path defaults to $XDG_RUNTIME_DIR/crow-pet.sock with a
+  // /tmp fallback so it works in desktop shells that don't set it.
+  const socketPath = process.env.CROW_PET_SOCKET
+    || (process.env.XDG_RUNTIME_DIR
+      ? `${process.env.XDG_RUNTIME_DIR}/crow-pet.sock`
+      : `/tmp/crow-pet-${process.getuid?.() ?? process.pid}.sock`);
+  try { if (existsSync(socketPath)) unlinkSync(socketPath); } catch { /* best-effort */ }
+  const petServer = net.createServer((conn) => {
+    conn.setEncoding("utf8");
+    let buf = "";
+    conn.on("data", (chunk) => {
+      buf += chunk;
+      let idx;
+      while ((idx = buf.indexOf("\n")) >= 0) {
+        const line = buf.slice(0, idx); buf = buf.slice(idx + 1);
+        if (!line.trim()) continue;
+        let msg;
+        try { msg = JSON.parse(line); } catch { conn.write(JSON.stringify({ ok: false, error: "bad-json" }) + "\n"); continue; }
+        if (msg.op === "anchor") {
+          const result = windowManager.setPetBounds(msg.spec || {});
+          conn.write(JSON.stringify(result) + "\n");
+        } else if (msg.op === "ping") {
+          conn.write(JSON.stringify({ ok: true, pid: process.pid }) + "\n");
+        } else {
+          conn.write(JSON.stringify({ ok: false, error: `unknown-op: ${msg.op}` }) + "\n");
+        }
+      }
+    });
+  });
+  petServer.listen(socketPath, () => {
+    try { require("fs").chmodSync(socketPath, 0o600); } catch { /* ok if umask already tight */ }
+  });
+  app.on("before-quit", () => {
+    try { petServer.close(); } catch {}
+    try { if (existsSync(socketPath)) unlinkSync(socketPath); } catch {}
+  });
+  // --- END CROW PATCH -----------------------------------------------
+
