{
  "id": "capstone-tracker",
  "name": "Capstone Tracker",
  "version": "1.0.0",
  "description": "PIR / notes / advocacy subsystems extracted from canvas-companion. Custom FastAPI bundle with bundle-owned SQLite at ~/.crow/data/capstone-tracker/capstone.db. E-reader deferred to Phase 4a.5.",
  "type": "bundle",
  "author": "kh0pp",
  "category": "research",
  "tags": ["pir", "research", "notes", "advocacy", "capstone"],
  "icon": "book",
  "docker": { "composefile": "docker-compose.yml" },
  "ports": [8090],
  "webUI": { "port": 8090, "path": "/", "label": "Capstone Tracker", "proxyMode": "subpath" },
  "env_vars": [
    {"name": "ZAI_API_KEY",                    "description": "Z.ai API key (digest generation)",                "required": true,  "secret": true},
    {"name": "ZAI_BASE_URL",                   "description": "Z.ai API base URL",                                "default": "https://api.z.ai/api/coding/paas/v4", "required": false},
    {"name": "ZAI_MODEL_ROUTINE",              "description": "Z.ai routine model alias",                         "default": "glm-4.5v",  "required": false},
    {"name": "ZAI_MODEL_COMPLEX",              "description": "Z.ai complex model alias",                         "default": "glm-4.6",   "required": false},
    {"name": "SMTP_HOST",                      "description": "SMTP server hostname",                             "default": "smtp.gmail.com", "required": true},
    {"name": "SMTP_PORT",                      "description": "SMTP server port",                                 "default": "587",       "required": true},
    {"name": "SMTP_USERNAME",                  "description": "SMTP login (Gmail address)",                       "required": true},
    {"name": "SMTP_PASSWORD",                  "description": "Gmail app password",                               "required": true,  "secret": true},
    {"name": "EMAIL_FROM",                     "description": "From: header for outgoing mail",                   "required": true},
    {"name": "EMAIL_TO",                       "description": "Destination for audit digests + alerts",           "required": true},
    {"name": "IMAP_HOST",                      "description": "IMAP hostname for email monitor",                  "default": "imap.gmail.com", "required": true},
    {"name": "IMAP_PORT",                      "description": "IMAP port",                                        "default": "993",       "required": true},
    {"name": "OCR_VISION_URL",                 "description": "OpenAI-compatible vision endpoint (local Qwen)",   "default": "http://100.118.41.122:8003/v1", "required": true},
    {"name": "OCR_VISION_MODEL",               "description": "Vision model alias",                               "default": "qwen3.6-35b-a3b", "required": true},
    {"name": "OCR_VISION_API_KEY",             "description": "API key for vision endpoint (llama-server: 'none')","default": "none",     "required": false},
    {"name": "CAPSTONE_TRACKER_INTERNAL_URL",  "description": "Self URL for in-container HTTP callbacks",         "default": "http://127.0.0.1:8000", "required": true}
  ],
  "skills": [],
  "requires": { "env": ["ZAI_API_KEY", "SMTP_PASSWORD"], "min_ram_mb": 2048, "min_disk_mb": 500 },
  "notes": "First custom-built (not upstream-image) bundle on crow. SMTP_PASSWORD sourced from ~/lab-maintenance/config/email.secret on grackle during deploy (see plan § 4.0.4). No MCP server (omit manifest.server). Subpath proxy mode — templates use Jinja's url_for() and JS uses window.BASE_URL injected by base.html, since the gateway mounts the bundle at /proxy/capstone-tracker/ not /. No panel UI in v1 (manifest.panel/panelRoutes omitted) — operator configures via ~/.crow/env/capstone-tracker.env directly. Skills deferred to Phase 4a.5 (none ship with v1)."
}
