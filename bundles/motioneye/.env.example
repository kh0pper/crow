# motionEye bundle configuration.
# Copy to .env and edit.

# Base URL of the motionEye server (loopback in the default docker-compose.yml).
MOTIONEYE_URL=http://localhost:8765

# Host paths for motionEye's config + recordings.
# Defaults live under ~/.crow/data/motioneye/ — create them before first start if you override.
# MOTIONEYE_CONFIG_PATH=~/.crow/data/motioneye/config
# MOTIONEYE_MEDIA_PATH=~/.crow/data/motioneye/media

# Host UID/GID that owns the mounted volumes. Run `id -u` / `id -g` on the host
# to find the right values. Leaving defaults (1000/1000) works for most single-user hosts.
# MOTIONEYE_UID=1000
# MOTIONEYE_GID=1000

# Timezone for timestamp overlays on recordings.
# TZ=America/Chicago
