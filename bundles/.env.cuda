# Shared env for grackle vLLM-CUDA specialist bundles.
# Resolved 2026-04-14. RTX 5060 Ti (Blackwell CC 12.0) + CUDA 12.8+ driver.

# vLLM >=0.11.0 required for Qwen3-VL. Pin to known-good tag in production.
VLLM_CUDA_IMAGE=vllm/vllm-openai:v0.11.0

# Tailscale IP for grackle (binding vLLM to tailnet only; LAN clients go through Tailscale)
GRACKLE_TAILSCALE_IP=100.121.254.89

# HF model cache on the dedicated model volume (326GB free after Phase 2 prune)
GRACKLE_HF_CACHE=/mnt/ollama-models/hf-cache

# Target instance id (used by manifest.host for cross-host dispatch)
GRACKLE_INSTANCE_ID=49cf71ca878643ba7717f344329266fd
