# Frigate NVR bundle configuration.
# Copy to .env and edit.

# Base URL of the Frigate server (authenticated UI + REST API on :8971).
# Our config.yml.example ships with tls.enabled=false so plain http:// works on loopback.
# If you re-enable Frigate TLS, flip to https:// AND export
# NODE_TLS_REJECT_UNAUTHORIZED=0 on the Crow gateway process (self-signed cert) —
# acceptable only for tailnet/loopback deployments.
FRIGATE_URL=http://localhost:8971

# Admin credentials for JWT login (POST /api/login → Bearer token).
# Omit if you have set `auth.enabled: false` in config.yml (local-only / proxy setups).
# FRIGATE_USER=admin
# FRIGATE_PASSWORD=

# Host paths for Frigate's config and recordings.
# Default to ~/.crow/data/frigate/{config,media} — create them before first start if you override.
# FRIGATE_CONFIG_PATH=~/.crow/data/frigate/config
# FRIGATE_MEDIA_PATH=~/.crow/data/frigate/media

# Frigate's built-in RTSP restreamer password. Must match the `rtsp.password` in config.yml.
# FRIGATE_RTSP_PASSWORD=
