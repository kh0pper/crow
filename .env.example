# Crow AI Platform - Environment Variables
# Copy this file to .env and fill in your values

# === Database ===
CROW_DB_PATH=./data/crow.db

# === Trello ===
# Get your API key at: https://trello.com/power-ups/admin
# Generate a token at: https://trello.com/1/authorize?expiration=never&scope=read,write&response_type=token&key=YOUR_API_KEY
TRELLO_API_KEY=
TRELLO_TOKEN=

# === Canvas LMS ===
# Generate a token in Canvas: Account > Settings > New Access Token
CANVAS_API_TOKEN=
CANVAS_BASE_URL=https://your-institution.instructure.com

# === Google Workspace ===
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
# Enable: Gmail API, Google Calendar API, Google Sheets API, Google Docs API, Google Slides API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Zotero (optional) ===
# Get your API key at: https://www.zotero.org/settings/keys
# Your user ID is at: https://www.zotero.org/settings/keys (shown at top)
ZOTERO_API_KEY=
ZOTERO_USER_ID=
