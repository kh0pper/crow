# Crow AI Platform - Environment Variables
# Copy this file to .env and fill in your values

# === Database ===
# For local development: uses a local SQLite file
CROW_DB_PATH=./data/crow.db
# For cloud deployment (Render, etc.): use Turso for persistent SQLite
# Create a free database at https://turso.tech and get your credentials
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# === Trello ===
# Get your API key at: https://trello.com/power-ups/admin
# Generate a token at: https://trello.com/1/authorize?expiration=never&scope=read,write&response_type=token&key=YOUR_API_KEY
TRELLO_API_KEY=
TRELLO_TOKEN=

# === Canvas LMS ===
# Generate a token in Canvas: Account > Settings > New Access Token
CANVAS_API_TOKEN=
CANVAS_BASE_URL=https://your-institution.instructure.com

# === Google Workspace ===
# Create OAuth credentials at: https://console.cloud.google.com/apis/credentials
# Enable: Gmail API, Google Calendar API, Google Sheets API, Google Docs API, Google Slides API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === Zotero (optional) ===
# Get your API key at: https://www.zotero.org/settings/keys
# Your user ID is at: https://www.zotero.org/settings/keys (shown at top)
ZOTERO_API_KEY=
ZOTERO_USER_ID=

# === Notion ===
# Create an integration at: https://www.notion.so/my-integrations
# Copy the "Internal Integration Secret"
# Then share your Notion pages/databases with the integration
NOTION_TOKEN=

# === Slack ===
# Create an app at: https://api.slack.com/apps
# Add Bot Token Scopes: channels:history, channels:read, chat:write, users:read
# Install to workspace and copy the Bot User OAuth Token (xoxb-...)
SLACK_BOT_TOKEN=

# === Discord (optional) ===
# Create a bot at: https://discord.com/developers/applications
# Enable Message Content Intent under Bot settings
# Copy the bot token
DISCORD_BOT_TOKEN=

# === Microsoft Teams (optional, experimental) ===
# Register an app at: https://portal.azure.com/#view/Microsoft_AAD_RegisteredApps
# Add Microsoft Graph permissions: Chat.Read, ChannelMessage.Read.All, ChannelMessage.Send
TEAMS_CLIENT_ID=
TEAMS_CLIENT_SECRET=
TEAMS_TENANT_ID=

# === GitHub ===
# Generate a personal access token at: https://github.com/settings/tokens
# Recommended scopes: repo, read:org, read:user, issues, pull_requests
GITHUB_PERSONAL_ACCESS_TOKEN=

# === Brave Search ===
# Get your API key at: https://brave.com/search/api/
BRAVE_API_KEY=

# === Filesystem ===
# Path to the root directory the filesystem server can access
# Defaults to /home if not set
CROW_FILES_PATH=/home

# === Render ===
# Get your API key at: https://render.com → Account Settings → API Keys
RENDER_API_KEY=

# === Mobile Access / Gateway ===
# These are used by the Streamable HTTP gateway for remote/mobile access
# Port the gateway listens on (default: 3001)
CROW_GATEWAY_PORT=3001
# Your deployed gateway URL (set after deploying to Render/Railway/etc.)
CROW_GATEWAY_URL=
# OAuth credentials (auto-generated if not set)
CROW_OAUTH_CLIENT_ID=
CROW_OAUTH_CLIENT_SECRET=
# Cloudflare Tunnel token (for local network deployment only)
CLOUDFLARE_TUNNEL_TOKEN=
