        { "id": "letter_of_intent",     "text": "Letter of intent (cover letter equivalent).",                                                                              "max_chars": 4000 },
        { "id": "leadership_philosophy","text": "Describe your educational leadership philosophy.",                                                                          "max_chars": 2000 },
        { "id": "equity_approach",      "text": "How do you approach equity and access in district leadership?",                                                            "max_chars": 1500 },
        { "id": "salary_expectations",  "text": "Salary expectations.",                                                                                                      "max_chars": 500  },
        { "id": "earliest_start",       "text": "Earliest available start date.",                                                                                            "max_chars": 500  }
      ]
    },
