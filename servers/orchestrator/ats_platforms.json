{
  "_meta": {
    "version": "1.0",
    "phase": "8.6",
    "created": "2026-05-12",
    "schema": {
      "platforms": "Array of platform definitions. URL is matched against url_patterns via case-insensitive substring.",
      "platform.questions": "Array of {id, text, max_chars}. max_chars is the hard limit; answers should fit comfortably under it.",
      "generic_fallback": "Used when url matches no platform. Five common categories most ATS platforms ask in some form."
    }
  },

  "platforms": [
    {
      "id": "tedk12",
      "name": "TEDK12 / Applitrack (K-12)",
      "url_patterns": ["tedk12.com", "applitrack.com", "talentedk12.com"],
      "notes": "Used by most TX/Southeast K-12 districts including SPRING ISD. Long-form, multi-section. Often asks essay-style leadership questions plus 5-10 short answers.",
      "questions": [
        { "id": "leadership_summary",   "text": "Briefly describe your educational leadership experience and approach.",                                                "max_chars": 2500 },
        { "id": "why_this_district",    "text": "Why are you interested in this district and this role specifically?",                                                    "max_chars": 1500 },
        { "id": "instructional_focus",  "text": "Describe your approach to instructional leadership and improving student outcomes.",                                     "max_chars": 2000 },
        { "id": "community_engagement", "text": "How do you engage families, staff, and community stakeholders in district decision-making?",                              "max_chars": 1500 },
        { "id": "operations_budget",    "text": "Describe your experience with operations, budget management, and resource allocation at scale.",                         "max_chars": 1500 },
        { "id": "salary_expectations",  "text": "What are your salary expectations for this position?",                                                                   "max_chars": 500  },
        { "id": "earliest_start",       "text": "When are you available to start? Earliest start date and current notice period.",                                        "max_chars": 500  },
        { "id": "certifications",       "text": "List your relevant administrator certifications and credentials.",                                                       "max_chars": 800  }
      ]
    },
    {
      "id": "frontline",
      "name": "Frontline Education (K-12)",
      "url_patterns": ["frontlineeducation.com", "recruitfront.com", "applicantpro.com"],
      "notes": "Frontline is the largest K-12 HR platform. Application format mirrors TEDK12 but with more structured fields. Often pre-populated from imported resume.",
      "questions": [
        { "id": "leadership_summary",     "text": "Summarize your educational leadership experience.",                                                                    "max_chars": 2000 },
        { "id": "why_this_role",          "text": "Why this role at this district?",                                                                                       "max_chars": 1500 },
        { "id": "instructional_approach", "text": "Your approach to instructional leadership and curriculum.",                                                              "max_chars": 1500 },
        { "id": "data_decisions",         "text": "Describe how you use data to drive district-level decisions.",                                                           "max_chars": 1500 },
        { "id": "salary_expectations",    "text": "Salary expectations.",                                                                                                    "max_chars": 500  },
        { "id": "earliest_start",         "text": "Earliest available start date.",                                                                                          "max_chars": 500  }
      ]
    },
    {
      "id": "edjoin",
      "name": "EdJoin (CA + multi-state K-12)",
